# PostgreSQL
POSTGRES_USER=board
POSTGRES_PASSWORD=board1234
POSTGRES_DB=board_db
POSTGRES_PORT=5432

# Backend (NestJS)
DATABASE_URL=postgresql://board:board1234@localhost:5432/board_db
BACKEND_PORT=4000
BCRYPT_ROUNDS=10
THROTTLE_TTL=60
THROTTLE_LIMIT=100  # 로컬 개발용. 프로덕션에서는 5로 변경

# Frontend (Next.js)
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
